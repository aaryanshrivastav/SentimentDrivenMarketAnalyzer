# API Keys for Data Collection
# Get these from the respective platforms

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=SentimentAnalyzer/1.0

# Optional: StockTwits API
STOCKTWITS_API_KEY=your_stocktwits_key_here

# Database Configuration (if needed)
DATABASE_URL=sqlite:///./data/app.db

# Model Paths
FINBERT_MODEL_PATH=./finbert_finetuned/best_model
LSTM_MODEL_PATH=./models/final_lstm_best.pt
XGBOOST_MODEL_PATH=./models/final_xgb_model.pkl

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Pipeline Settings
DEFAULT_TICKERS=AAPL,TSLA,GME,NVDA
START_DATE=2024-01-01
END_DATE=2024-12-31

# Processing Options
USE_FINETUNED_FINBERT=true
ENABLE_SARCASM_DETECTION=true
ENABLE_BOT_DETECTION=true
MIN_CREDIBILITY_SCORE=0.3

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/pipeline.log
